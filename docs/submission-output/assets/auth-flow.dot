digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad=0.18, nodesep=0.36, ranksep=0.52, splines=ortho];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=12, color="#94A3B8", fillcolor="#FFFFFF", fontcolor="#17324D", margin="0.16,0.10"];
  edge [color="#64748B", penwidth=1.5, arrowsize=0.72];
  login [label="用户名 + 密码", fillcolor="#DBEAFE", color="#2563EB"];
  hash [label="Werkzeug scrypt\n旧 SHA-256 兼容"];
  jwt [label="签发 Bearer JWT\n有效期 24 小时", fillcolor="#D1FAE5", color="#0F766E"];
  header [label="Authorization\nBearer <token>"];
  auth [label="require_auth\n验证身份", fillcolor="#E0F2FE", color="#0891B2"];
  role [label="require_merchant\n验证 role=merchant", fillcolor="#FEF3C7", color="#D97706"];
  login -> hash -> jwt -> header -> auth -> role;
}
