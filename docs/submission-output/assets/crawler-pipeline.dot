digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad=0.2, nodesep=0.35, ranksep=0.48, splines=ortho];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=13, color="#94A3B8", fillcolor="#FFFFFF", fontcolor="#17324D", margin="0.16,0.10"];
  edge [color="#64748B", penwidth=1.6, arrowsize=0.75];
  a [label="关键词与品类\n映射表", fillcolor="#DBEAFE", color="#2563EB"];
  b [label="构造搜索 URL\nSession 请求"];
  c [label="状态码 / 验证页\n双重检测", fillcolor="#FEF3C7", color="#D97706"];
  d [label="BeautifulSoup\nCSS 解析"];
  e [label="字段提取\n清洗与估算"];
  f [label="product_id\n内存去重", fillcolor="#D1FAE5", color="#0F766E"];
  g [label="翻页 + 限速\n失败重试"];
  h [label="PostgreSQL 入库\n评论生成", fillcolor="#D1FAE5", color="#0F766E"];
  a -> b -> c -> d -> e -> f -> g -> h;
  c -> g [label="拦截/失败", fontname="Noto Sans CJK SC", fontsize=10, color="#B91C1C", fontcolor="#B91C1C"];
}
