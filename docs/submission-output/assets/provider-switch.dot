digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad=0.2, nodesep=0.42, ranksep=0.55, splines=ortho];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=13, color="#94A3B8", fillcolor="#FFFFFF", fontcolor="#17324D", margin="0.18,0.11"];
  edge [color="#64748B", penwidth=1.6, arrowsize=0.75, fontname="Noto Sans CJK SC", fontsize=10];
  api [label="业务 API\n6 类 AI 能力", fillcolor="#DBEAFE", color="#2563EB"];
  factory [label="get_ai_provider\n统一工厂"];
  env [label="AI_PROVIDER\n环境变量", fillcolor="#FEF3C7", color="#D97706"];
  mock [label="MockAIService\n确定性 · 零外部依赖", fillcolor="#D1FAE5", color="#0F766E"];
  openai [label="OpenAIProvider\n真实 LLM · 结构化 JSON", fillcolor="#E0F2FE", color="#0891B2"];
  out [label="统一响应协议\n前端无感切换", fillcolor="#DBEAFE", color="#2563EB"];
  api -> factory -> env;
  env -> mock [label="mock（默认）"];
  env -> openai [label="openai"];
  mock -> out;
  openai -> out;
}
