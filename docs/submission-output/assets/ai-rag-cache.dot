digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad=0.18, nodesep=0.34, ranksep=0.52, splines=ortho];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=12, color="#94A3B8", fillcolor="#FFFFFF", fontcolor="#17324D", margin="0.16,0.10"];
  edge [color="#64748B", penwidth=1.5, arrowsize=0.72];
  q [label="商品与用户问题", fillcolor="#DBEAFE", color="#2563EB"];
  cache [label="Redis\n命中直接返回", shape=cylinder, fillcolor="#FEF3C7", color="#D97706"];
  rag [label="RAG\n商品候选 + 知识上下文", fillcolor="#D1FAE5", color="#0F766E"];
  factory [label="AI Provider 工厂"];
  mock [label="Mock\n确定性生成", fillcolor="#E0F2FE", color="#0891B2"];
  openai [label="OpenAI 兼容接口\nKey · Model · Base URL", fillcolor="#DBEAFE", color="#2563EB"];
  answer [label="结构化回答\n写入缓存", fillcolor="#D1FAE5", color="#0F766E"];
  q -> cache;
  cache -> rag [label="未命中/不可用", fontname="Noto Sans CJK SC", fontsize=9];
  rag -> factory;
  factory -> mock;
  factory -> openai;
  mock -> answer;
  openai -> answer;
}
