digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad=0.2, nodesep=0.26, ranksep=0.34, splines=ortho];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=11.5, color="#94A3B8", fillcolor="#FFFFFF", fontcolor="#17324D", margin="0.14,0.08"];
  edge [color="#64748B", penwidth=1.4, arrowsize=0.68, fontname="Noto Sans CJK SC", fontsize=9];
  q [label="原始问题", fillcolor="#DBEAFE", color="#2563EB"];
  history [label="最近 5 轮历史\n补全指代/追问"];
  recall [label="多路召回", fillcolor="#FEF3C7", color="#D97706"];
  exact [label="精确商品名"];
  category [label="分类 + 核心词"];
  global [label="通用词全局"];
  brand [label="品牌知识"];
  rerank [label="Rerank\n路径权重 + 匹配度 + 评分", fillcolor="#E0F2FE", color="#0891B2"];
  hit [label="最佳商品\n+ 最近10条评论\n+ 同类Top5\n+ 知识库上下文", fillcolor="#D1FAE5", color="#0F766E"];
  fallback [label="AI / Mock 兜底", fillcolor="#FEE2E2", color="#B91C1C"];
  q -> history -> recall;
  recall -> exact;
  recall -> category;
  recall -> global;
  recall -> brand;
  exact -> rerank;
  category -> rerank;
  global -> rerank;
  brand -> rerank;
  rerank -> hit [label="有候选"];
  rerank -> fallback [label="无候选/异常"];
}
