digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad=0.18, nodesep=0.34, ranksep=0.55, splines=ortho];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=12, color="#94A3B8", fillcolor="#FFFFFF", fontcolor="#17324D", margin="0.16,0.10"];
  edge [color="#64748B", penwidth=1.5, arrowsize=0.72];
  env [label="环境变量\nAppConfig", fillcolor="#DBEAFE", color="#2563EB"];
  app [label="create_app()\n创建 Flask 应用"];
  ext [label="绑定扩展\nJWT + CORS", fillcolor="#E0F2FE", color="#0891B2"];
  err [label="健康检查\n错误处理器"];
  db [label="init_db()\n本地初始化", fillcolor="#D1FAE5", color="#0F766E"];
  user [label="默认账号\n不存在则创建", fillcolor="#FEF3C7", color="#D97706"];
