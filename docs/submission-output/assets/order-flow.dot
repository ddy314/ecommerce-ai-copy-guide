digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad=0.2, nodesep=0.36, ranksep=0.5, splines=ortho];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=14, penwidth=1.6, margin="0.20,0.12"];
  edge [color="#64748B", penwidth=1.8, arrowsize=0.8, fontname="Noto Sans CJK SC", fontsize=10];
  pending [label="待支付\npending", fillcolor="#FEF3C7", color="#D97706", fontcolor="#92400E"];
  paid [label="已支付\npaid", fillcolor="#DBEAFE", color="#2563EB", fontcolor="#1D4ED8"];
  shipped [label="已发货\nshipped", fillcolor="#E0F2FE", color="#0891B2", fontcolor="#0E7490"];
  completed [label="已完成\ncompleted", fillcolor="#D1FAE5", color="#0F766E", fontcolor="#047857"];
  cancelled [label="已取消\ncancelled", fillcolor="#FEE2E2", color="#B91C1C", fontcolor="#991B1B"];
  pending -> paid [label="用户支付"];
  paid -> shipped [label="商家发货"];
  shipped -> completed [label="用户收货"];
  pending -> cancelled [label="用户取消", color="#B91C1C", fontcolor="#B91C1C"];
}
